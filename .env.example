SECRET_KEY=change-this-secret

# MySQL / ServBay
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=ServBay.dev
DB_NAME=gmaps_scraper

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Default admin seed
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@rorojonggrang.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_FULL_NAME=Administrator

# Scraper defaults
HEADLESS=false
SCRAPE_DELAY_MIN=3
SCRAPE_DELAY_MAX=8
MAX_SCROLL_ATTEMPTS=20
BROWSER_RESTART_EVERY=50

# Optional browser paths if Selenium auto-detection is problematic
# CHROME_BINARY_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# CHROMEDRIVER_PATH=/opt/homebrew/bin/chromedriver
